function meckColor(pct) {
  if (pct >= 75) return '#8b1515';
  if (pct >= 55) return '#6b1212';
  return '#4a1010';
}
function wakeColor(score) {
  if (score >= 0.10) return '#1a4a78';
  if (score >= 0.07) return '#133860';
  return '#0d2848';
}

function makePoly(svg, pts, fill, stroke, title, onEnter, onLeave, onClick) {
  const p = document.createElementNS('http://www.w3.org/2000/svg','polygon');
  p.setAttribute('points', pts);
  p.setAttribute('fill', fill);
  p.setAttribute('stroke', stroke);
  p.setAttribute('stroke-width', '0.5');
  if (title) {
    p.style.cursor = 'pointer';
    p.addEventListener('mouseenter', onEnter);
    p.addEventListener('mouseleave', onLeave);
    if (onClick) p.addEventListener('click', onClick);
  }
  svg.appendChild(p);
  return p;
}

function buildMeck() {
  const svg = document.getElementById('meck-svg');
  const tt = document.getElementById('meck-tt');
  // Background tracts
  for (const [id, pts] of Object.entries(meckBG)) {
    makePoly(svg, pts, '#1a2e3a', '#0e1821', null, null, null, null);
  }
  // High-risk tracts
  for (const [id, pts] of Object.entries(meckPts)) {
    const d = meckHR[id];
    const fill = meckColor(d.pct);
    const p = makePoly(svg, pts, fill, '#cc3333',
      `Tract ${id}`, 
      (e) => {
        p.setAttribute('fill', '#cc2222');
        p.setAttribute('stroke-width','1');
        tt.innerHTML = `<strong>Tract ${id}</strong><br>${d.pct.toFixed(1)}% at-risk · ${d.resp}% Census response<br>${d.pop.toLocaleString()} at-risk residents of ${d.total.toLocaleString()}`;
        tt.style.display = 'block';
        tt.style.top = (e.offsetY - 60) + 'px';
        tt.style.left = (e.offsetX + 8) + 'px';
      },
      () => {
        p.setAttribute('fill', fill);
        p.setAttribute('stroke-width','0.5');
        tt.style.display = 'none';
      },
      null
    );
    // Label
    const pts_arr = pts.split(' ').map(s => s.split(',').map(Number));
    const cx = pts_arr.reduce((a,b)=>a+b[0],0)/pts_arr.length;
    const cy = pts_arr.reduce((a,b)=>a+b[1],0)/pts_arr.length;
    const t = document.createElementNS('http://www.w3.org/2000/svg','text');
    t.setAttribute('x', cx); t.setAttribute('y', cy);
    t.setAttribute('text-anchor','middle'); t.setAttribute('dominant-baseline','central');
    t.setAttribute('font-size','8'); t.setAttribute('fill','#ffaaaa');
    t.setAttribute('font-family','var(--font-sans)'); t.setAttribute('pointer-events','none');
    t.textContent = id;
    svg.appendChild(t);
  }
}

